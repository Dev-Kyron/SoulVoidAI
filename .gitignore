# Dependencies & build output
node_modules/
out/
dist/
release/

# Logs & temporary files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/
coverage/

# OS metadata
.DS_Store
Thumbs.db
desktop.ini

# Environment files (explicit + glob; the bare `.env` rule already covers
# the unsuffixed file, the glob picks up `.env.development`, `.env.staging`,
# etc. which secret-bearing setups produce)
.env
.env.*

# Editor / IDE
.vscode/*
!.vscode/extensions.json
!.vscode/settings.shared.json
.idea/

# TypeScript incremental build state
*.tsbuildinfo

# Local app data the dev build writes
voidsoul-data/

# Tesseract OCR model data — tesseract.js fetches this at runtime from its
# CDN and caches it under the OS app-data folder. Leftover copies in the
# repo root would just bloat the working tree.
eng.traineddata
*.traineddata

# Piper TTS binary — downloaded per-platform by `npm run piper` into
# resources/piper/<platform>/piper/. ~30 MB blob we never want in git.
resources/piper/

# Piper voice models — the user's local dev copies live under Voices/
# (large .onnx files). Production reads from the OS user-data dir; the
# repo-rooted folder is dev-only and never gets committed.
Voices/
voices/
