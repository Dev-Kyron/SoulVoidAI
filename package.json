{
  "name": "voidsoul-ai-companion",
  "version": "1.7.3",
  "description": "A local-first AI companion for creators and developers — voice-first, multi-provider, runs on Ollama out of the box.",
  "author": {
    "name": "Void Soul Studio",
    "url": "https://voidsoulstudio.com"
  },
  "license": "SEE LICENSE IN LICENSE",
  "private": true,
  "main": "./out/main/index.js",
  "keywords": [
    "electron",
    "ai",
    "assistant",
    "ollama",
    "local-first",
    "agent",
    "mcp",
    "rag",
    "wake-word",
    "voice"
  ],
  "engines": {
    "node": ">=20.18"
  },
  "scripts": {
    "icons": "node scripts/generate-icons.mjs",
    "piper": "node scripts/download-piper.mjs",
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "build": "npm run typecheck && electron-vite build",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "npm run typecheck",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,css,md}\"",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css,md}\"",
    "package": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@picovoice/porcupine-web": "^4.0.0",
    "@picovoice/web-voice-processor": "^4.0.10",
    "@types/qrcode": "^1.5.6",
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^11.10.0",
    "docx": "^9.6.1",
    "electron-updater": "^6.8.3",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.47",
    "lucide-react": "^0.456.0",
    "mammoth": "^1.12.0",
    "mermaid": "^11.15.0",
    "pdf-parse": "^2.4.5",
    "qrcode": "^1.5.4",
    "react-markdown": "^9.0.1",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "systeminformation": "^5.31.6",
    "tesseract.js": "^5.1.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "clsx": "^2.1.1",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "framer-motion": "^11.11.17",
    "happy-dom": "^15.11.7",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.9",
    "zustand": "^5.0.1"
  }
}
